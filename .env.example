# =============================================================
# AgenticAI for BO — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.

# AI Provider: "openai" or "gemini"
AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Google Gemini Configuration
GEMINI_API_KEY=""
GEMINI_MODEL=gemini-2.0-flash

# SAP Business Objects & Tomcat Log Directories
# Comma-separate multiple directories
#   /data/sap_bobj/enterprise_xi40/logging   — SAP BO core logs
#   /data/sap_bobj/tomcat/logs               — Tomcat logs
SAP_BO_LOG_DIR=/data/sap_bobj/enterprise_xi40/logging,/data/sap_bobj/tomcat/logs


# Output Directory for Reports
REPORT_OUTPUT_DIR=./reports
