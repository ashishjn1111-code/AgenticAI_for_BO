# =============================================================
# AgenticAI for BO — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.

# AI Provider: "openai" or "gemini"
AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Google Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-pro

# SAP Business Objects Log Directory
# Linux examples:
#   /opt/sap_bobj/enterprise_xi40/logging
#   /usr/sap/bobj/enterprise_xi40/logging
#   /home/boadmin/sap_bobj/logging
# Windows example:
#   C:/Program Files (x86)/SAP BusinessObjects/SAP BusinessObjects Enterprise XI 4.0/logging
SAP_BO_LOG_DIR=/opt/sap_bobj/enterprise_xi40/logging

# Output Directory for Reports
REPORT_OUTPUT_DIR=./reports
