# AgenticAI for BO — Git Ignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual Environment
venv/
.venv/
env/

# Environment Variables (contains secrets)
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store

# Reports (generated output)
reports/

# Logs (test data — don't commit large log files)
logs/
*.log
*.glf
*.trc
